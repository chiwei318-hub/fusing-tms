modules = ["nodejs-24", "python3", "python-3.12", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
APP_BASE_URL = "https://25aa9280-967a-471c-b4c8-f7fae9a96c57-00-13weca2s6r6nq.worf.replit.dev"
INVOICE_PROVIDER = "mock"
INVOICE_API_BASE = ""
INVOICE_MERCHANT_ID = ""
ATOMS_CALLBACK_BASE_URL = "https://25aa9280-967a-471c-b4c8-f7fae9a96c57-00-13weca2s6r6nq.worf.replit.dev"
SHOPEE_SCHEDULE_SHEET_ID = "1JQR9RUtxmMt6VhxG_3on-1ftiQKzKQpFI8GO6JuBLvI"

[userenv.production]
