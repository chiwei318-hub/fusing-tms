modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
APP_BASE_URL = "https://25aa9280-967a-471c-b4c8-f7fae9a96c57-00-13weca2s6r6nq.worf.replit.dev"
INVOICE_PROVIDER = "mock"
INVOICE_API_BASE = ""
INVOICE_MERCHANT_ID = ""
ATOMS_WEBHOOK_URL = "https://2ekee8.pub.atoms.dev/api/webhook/orders"
